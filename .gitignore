# Backup files
*~

# python cache
__pycache__/

# package meta data
*.egg-info/

# juypter internals
.ipynb_checkpoints/

# poetry lock
poetry.lock

# for wheel
dist/

# ruff
.ruff_cache/

# data files downloaded and the db built
# (do not ignore tests/data/ , which has some custom data files for tests)
/data/
src/go/data/

# tests/data contains custom csv / sh,
# but the combined master .csv / .db are still generated and to be tested
tests/data/tess_dv_fast/tess_tcestats.*


# for gcloud, etc.
build/

# Go version (of the webapp) binary outputs
src/go/tess_dv_fast_server*
# e.g. server.log might be created during dev/testing
src/go/*.log
# generated build SHA for Go version
src/go/build.txt
